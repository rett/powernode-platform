#!/usr/bin/env bash
set -e

# Rails development server script that binds to all interfaces
echo "Starting Rails API development server on all interfaces..."
echo "Server will be accessible at:"
echo "  - http://localhost:3000 (local)"
echo "  - http://0.0.0.0:3000 (all interfaces)"
echo "  - http://$(hostname -I | awk '{print $1}'):3000 (network IP)"
echo ""

# Start Rails server bound to all interfaces
bundle exec rails server -b 0.0.0.0 -p 3000
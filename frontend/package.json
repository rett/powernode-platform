{
  "name": "frontend",
  "version": "0.0.1-dev",
  "private": true,
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.1.9",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@uiw/react-md-editor": "^4.0.8",
    "axios": "^1.11.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.539.0",
    "react": "^19.1.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.1.2",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4",
    "ws": "^8.18.3"
  },
  "scripts": {
    "start": "NODE_OPTIONS='--no-deprecation' react-scripts start",
    "dev": "NODE_OPTIONS='--no-deprecation' HOST=0.0.0.0 react-scripts start",
    "build": "NODE_OPTIONS='--no-deprecation' react-scripts build",
    "build:verbose": "react-scripts build",
    "test": "NODE_OPTIONS='--no-deprecation' react-scripts test",
    "test:verbose": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:security": "eslint src --ext .ts,.tsx --config .eslintrc.security.js",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "security"
    ],
    "rules": {
      "security/detect-object-injection": "error",
      "security/detect-non-literal-regexp": "error",
      "security/detect-possible-timing-attacks": "error",
      "security/detect-pseudoRandomBytes": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@cypress/react": "^9.0.1",
    "@cypress/webpack-dev-server": "^4.1.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/user-event": "^14.6.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cypress": "^14.5.4",
    "eslint-plugin-security": "^3.0.1",
    "identity-obj-proxy": "^3.0.0",
    "postcss": "^8.5.6",
    "redux-mock-store": "^1.5.5",
    "tailwindcss": "^3.4.17"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-router|react-router-dom)/)"
    ],
    "moduleNameMapper": {
      "^axios$": "axios/dist/node/axios.cjs",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "@uiw/react-md-editor": "<rootDir>/src/__mocks__/@uiw/react-md-editor.js",
      "react-markdown": "<rootDir>/src/__mocks__/react-markdown.js"
    }
  }
}

    "@types/react-router-dom": "^5.3.3",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@uiw/react-md-editor": "^4.0.8",
    "@xyflow/react": "^12.8.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.539.0",
    "react": "^19.1.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-is": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.1.2",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4",
    "ws": "^8.18.3"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:full": "tsc && vite build",
    "build:verbose": "vite build --debug",
    "refresh-proxy": "node scripts/refresh-proxy-cache.js",
    "test": "NODE_OPTIONS='--no-deprecation --experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--no-deprecation --experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--no-deprecation --experimental-vm-modules' jest --coverage",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --config .eslintrc.js",
    "lint:fix": "eslint src --ext .ts,.tsx --config .eslintrc.js --fix",
    "lint:security": "eslint src --ext .ts,.tsx --config .eslintrc.security.js",
    "lint:production": "eslint src --ext .ts,.tsx --config .eslintrc.production.js",
    "lint:check": "eslint --print-config .eslintrc.js",
    "typecheck": "tsc --noEmit",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:parallel": "cypress-split",
    "cypress:parallel:2": "npm run cypress:parallel -- --split 2",
    "cypress:parallel:4": "npm run cypress:parallel -- --split 4"
  },
  "eslintConfig": {
    "plugins": [
      "security"
    ],
    "rules": {
      "security/detect-object-injection": "error",
      "security/detect-non-literal-regexp": "error",
      "security/detect-possible-timing-attacks": "error",
      "security/detect-pseudoRandomBytes": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "@types/d3-dispatch": "3.0.6"
  },
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@cypress/react": "^9.0.1",
    "@cypress/webpack-dev-server": "^4.1.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/glob": "^8.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cypress": "^14.5.4",
    "cypress-split": "^1.24.25",
    "eslint-plugin-security": "^3.0.1",
    "glob": "^11.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "postcss": "^8.5.6",
    "redux-mock-store": "^1.5.5",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^4.3.2"
  }
}

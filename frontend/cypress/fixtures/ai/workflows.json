    {
      "id": "01HX9R8C8V2NP3QWKJ5WORKFLOW2",
      "name": "Support Ticket Triage",
      "description": "Automatically categorize and route support tickets",
      "status": "active",
      "visibility": "team",
      "trigger_type": "webhook",
      "trigger_config": {
        "endpoint": "/webhooks/support-ticket"
      },
      "steps": [
        {
          "id": "step-1",
          "type": "ai_classify",
          "name": "Classify Ticket",
          "config": { "categories": ["billing", "technical", "general"] }
        },
        {
          "id": "step-2",
          "type": "condition",
          "name": "Check Priority",
          "config": { "field": "priority", "operator": "equals", "value": "high" }
        },
        {
          "id": "step-3",
          "type": "assign",
          "name": "Assign to Team",
          "config": { "assignment_rule": "round_robin" }
        }
      ],
      "created_at": "2024-10-20T09:00:00Z",
      "updated_at": "2024-12-15T11:00:00Z",
      "last_run_at": "2024-12-20T09:45:00Z",

#!/usr/bin/env bash
set -e

# React development server script that binds to all interfaces
echo "Starting React development server on all interfaces..."
echo "Server will be accessible at:"
echo "  - http://localhost:3001 (local)"
echo "  - http://0.0.0.0:3001 (all interfaces)"
echo "  - http://$(hostname -I | awk '{print $1}'):3001 (network IP)"
echo ""
echo "API should be running on port 3000"
echo ""

# Set environment variables and start React dev server
export HOST=0.0.0.0
export PORT=3001
export BROWSER=none

npm start
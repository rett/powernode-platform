# Application Version
REACT_APP_VERSION=0.0.2
VITE_APP_VERSION=0.0.2

# API Configuration  
REACT_APP_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_BASE_URL=http://localhost:3000/api/v1
REACT_APP_WS_BASE_URL=ws://localhost:3000/cable
VITE_WS_BASE_URL=ws://localhost:3000/cable

# Development Settings
REACT_APP_AUTO_DETECT_BACKEND=true
VITE_AUTO_DETECT_BACKEND=true

# Reverse Proxy Configuration
# Set to true if running behind a reverse proxy (nginx, Apache, etc.)
# When true, API calls will use the same host/port as the frontend
# REACT_APP_BEHIND_PROXY=false
# VITE_BEHIND_PROXY=false

# Vite HMR Configuration for Reverse Proxy
# Uncomment and configure these when behind a reverse proxy
# VITE_PROXY_HOST=your-domain.com
# VITE_PROXY_PROTOCOL=https

# Additional allowed hosts (comma-separated)
# Use this to allow additional domains to access the dev server
# VITE_ALLOWED_HOSTS=custom.domain.com,another.domain.com

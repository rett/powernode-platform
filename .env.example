# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/powernode_production

# Rails Configuration
RAILS_ENV=production
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here
JWT_SECRET_KEY=your_jwt_secret_key_for_token_signing_should_be_at_least_32_characters_long

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Payment Gateway Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# Email Configuration (for notifications and password reset)
SMTP_ADDRESS=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USERNAME=your_email_username
SMTP_PASSWORD=your_email_password
SMTP_DOMAIN=your-domain.com
FROM_EMAIL=noreply@your-domain.com

# Application Configuration
APP_DOMAIN=your-domain.com
FRONTEND_URL=https://your-domain.com
API_URL=https://api.your-domain.com

# Security Configuration
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Monitoring & Logging (optional)
SENTRY_DSN=https://your-sentry-dsn-here
LOG_LEVEL=info

# Background Jobs
SIDEKIQ_WEB_USERNAME=admin
SIDEKIQ_WEB_PASSWORD=your_secure_admin_password

# SSL Certificate (for production)
SSL_CERT_PATH=/path/to/your/ssl/cert.pem
SSL_KEY_PATH=/path/to/your/ssl/private.key
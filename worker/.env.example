# Powernode Worker Service Environment Configuration

# Worker Environment
WORKER_ENV=development

# Backend API Configuration
BACKEND_API_URL=http://localhost:3000
SERVICE_TOKEN=your-service-token-here
API_TIMEOUT=30
MAX_RETRY_ATTEMPTS=3

# Redis Configuration
REDIS_URL=redis://localhost:6379/1

# Sidekiq Configuration
WORKER_CONCURRENCY=5
WORKER_QUEUES=critical,billing,reports,webhooks,default

# Sidekiq Web Interface (configured to listen on all IPs: 0.0.0.0)
SIDEKIQ_WEB_PORT=4567
SIDEKIQ_WEB_HOST=0.0.0.0

# Logging
LOG_LEVEL=info
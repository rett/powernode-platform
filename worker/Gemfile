source 'https://rubygems.org'
git_source(:github) { |repo| "https://github.com/#{repo}.git" }

ruby '3.2.8'

# Background job processing
gem 'sidekiq', '~> 7.2'
gem 'sidekiq-scheduler', '~> 5.0'

# HTTP client for API communication
gem 'faraday', '~> 2.7'
gem 'faraday-retry', '~> 2.2'

# HTTP client for direct AI provider calls (adapters use HTTParty for non-streaming)
gem 'httparty', '~> 0.21'

# Configuration and environment
gem 'dotenv', '~> 3.0'

# Core Ruby extensions (needed for time helpers like .day, .hours, etc.)
gem 'activesupport', '~> 7.1'

# Email functionality
gem 'actionmailer', '~> 7.1'

# JSON handling
gem 'oj', '~> 3.16'

# Logging and debugging
gem 'amazing_print', '~> 1.5'

# Redis connection
gem 'redis', '~> 5.0'
gem 'connection_pool', '~> 2.4'

# Web server for Sidekiq web interface
gem 'rackup', '~> 2.1'
gem 'puma', '~> 6.4'

# Session middleware for Sidekiq web authentication
gem 'rack-session', '~> 2.0'

# Security for service authentication
gem 'jwt', '~> 2.7'

# Ethereum key generation, transaction signing
gem 'eth', '~> 0.5'

# File processing
gem 'mini_magick', '~> 4.12'        # Image processing
gem 'mini_exiftool', '~> 2.11'     # EXIF data extraction
gem 'streamio-ffmpeg', '~> 3.0'    # Video/audio processing

# Payment providers (for reconciliation)
gem 'stripe', '~> 18.0', require: false
gem 'paypal-sdk-rest', '~> 1.7', require: false

# Document generation
gem 'prawn', '~> 2.4'               # PDF generation
gem 'prawn-table', '~> 0.2'         # PDF table support
gem 'caxlsx', '~> 4.0'              # XLSX generation

# Notification providers
gem 'twilio-ruby', '~> 7.10'        # Twilio SMS
gem 'googleauth', '~> 1.8'          # Firebase auth
gem 'google-apis-fcm_v1', '~> 0.6'  # Firebase Cloud Messaging

# WebSocket support for MCP
gem 'websocket-client-simple', '~> 0.8'

# Development and testing
group :development, :test do
  gem 'pry', '~> 0.14'
  gem 'rspec', '~> 3.12'
  gem 'webmock', '~> 3.19'
  gem 'vcr', '~> 6.2'
end

# Production
group :production do
  gem 'foreman', '~> 0.87'
end